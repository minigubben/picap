<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= brand.name %> | Sign in</title>
    <link rel="icon" type="image/svg+xml" href="<%= brand.faviconPath %>" />
    <% (clientAssets?.css || []).forEach((href) => { %>
      <link rel="stylesheet" href="<%= href %>" />
    <% }) %>
  </head>
  <body class="min-h-screen bg-black text-zinc-100 antialiased">
    <main class="mx-auto flex min-h-screen w-full max-w-6xl items-center px-6 py-10">
      <section class="grid w-full gap-10 lg:grid-cols-[1.05fr_0.95fr]">
        <div class="hidden border-l border-zinc-800 pl-8 lg:block">
          <div class="mb-6 flex items-center gap-4">
            <img src="<%= brand.logoPath %>" alt="<%= brand.name %> logo" class="h-16 w-16 border border-lime-500/40 bg-zinc-950 object-cover p-1" />
            <div>
              <p class="text-xs uppercase tracking-[0.34em] text-lime-400/80">Packet Capture</p>
              <p class="mt-2 text-2xl font-semibold text-zinc-50"><%= brand.name %></p>
            </div>
          </div>
          <h1 class="max-w-3xl text-5xl font-semibold leading-tight text-zinc-50">
            Capture mirrored traffic from the Pi without leaving the bench.
          </h1>
          <p class="mt-6 max-w-2xl text-lg leading-8 text-zinc-400">
            Start filtered tcpdump runs, rotate long captures into practical chunks, and pull pcap files when the job is done.
          </p>
        </div>
        <div class="border border-zinc-800 bg-zinc-950/80 px-6 py-8">
          <div class="mb-5 flex items-center gap-3 lg:hidden">
            <img src="<%= brand.logoPath %>" alt="<%= brand.name %> logo" class="h-12 w-12 border border-lime-500/40 bg-zinc-950 object-cover p-1" />
            <div>
              <p class="text-xs uppercase tracking-[0.34em] text-lime-400/80">Packet Capture</p>
              <p class="mt-1 text-xl font-semibold text-zinc-50"><%= brand.name %></p>
            </div>
          </div>
          <p class="mb-3 text-xs uppercase tracking-[0.34em] text-zinc-500">Admin Access</p>
          <h2 class="text-3xl font-semibold text-zinc-50">Sign in</h2>
          <p class="mt-3 max-w-md text-sm leading-6 text-zinc-400">
            Use the local admin password configured by environment variables.
          </p>
          <% if (error) { %>
            <p class="mt-6 border border-red-950 bg-red-950/30 px-4 py-3 text-sm text-red-200"><%= error %></p>
          <% } %>
          <form method="post" action="/login" class="mt-8 space-y-5">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <div class="space-y-2">
              <label for="password" class="block text-xs uppercase tracking-[0.28em] text-zinc-500">Password</label>
              <input
                id="password"
                type="password"
                name="password"
                required
                class="w-full border border-zinc-800 bg-zinc-900 px-4 py-3 text-base text-zinc-100 outline-none transition focus:border-zinc-600"
              />
            </div>
            <button type="submit" class="inline-flex items-center justify-center border border-zinc-700 bg-zinc-100 px-5 py-3 text-sm font-medium text-black transition hover:bg-zinc-300">
              Sign in
            </button>
          </form>
        </div>
      </section>
    </main>
  </body>
</html>
