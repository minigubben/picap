<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= brand.name %> | Control</title>
    <link rel="icon" type="image/svg+xml" href="<%= brand.faviconPath %>" />
    <script>
      window.CSRF_TOKEN = "<%= csrfToken %>";
    </script>
    <% (clientAssets?.css || []).forEach((href) => { %>
      <link rel="stylesheet" href="<%= href %>" />
    <% }) %>
    <% (clientAssets?.js || []).forEach((src) => { %>
      <script src="<%= src %>" type="module"></script>
    <% }) %>
  </head>
  <body class="min-h-screen bg-black text-zinc-100 antialiased">
    <main class="min-h-screen">
      <section class="border-b border-zinc-800">
        <div class="mx-auto flex max-w-[1800px] flex-wrap items-start justify-between gap-6 px-5 py-5">
          <div class="flex items-start gap-4">
            <img src="<%= brand.logoPath %>" alt="<%= brand.name %> logo" class="h-16 w-16 border border-lime-500/40 bg-zinc-950 object-cover p-1" />
            <div>
              <p class="text-xs uppercase tracking-[0.34em] text-lime-400/80">Packet Capture</p>
              <h1 class="mt-2 text-4xl font-semibold text-zinc-50"><%= brand.name %></h1>
            </div>
          </div>
          <div class="min-w-0 flex-1">
            <p class="mt-3 max-w-3xl text-sm leading-6 text-zinc-400">
              Capture from <code class="text-zinc-300"><%= services.config.captureInterface %></code>, manage <code class="text-zinc-300"><%= services.config.wifiInterface %></code>, and download rotated pcap artifacts.
            </p>
          </div>
          <form method="post" action="/logout">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <button type="submit" class="border border-zinc-800 bg-zinc-900 px-4 py-2 text-sm text-zinc-100 transition hover:bg-zinc-800">
              Sign out
            </button>
          </form>
        </div>
        <div class="mx-auto max-w-[1800px] px-5 pb-4">
          <p class="text-sm text-zinc-300" data-ui-status><%= statusMessage || "" %></p>
        </div>
      </section>

      <section class="mx-auto grid max-w-[1800px] lg:grid-cols-[minmax(360px,0.45fr)_minmax(0,0.55fr)]">
        <aside class="border-b border-zinc-800 lg:border-b-0 lg:border-r">
          <%- include("partials/capture-form") %>
          <%- include("partials/network-panel") %>
        </aside>

        <section>
          <div class="border-b border-zinc-800 px-5 py-5">
            <p class="text-xs uppercase tracking-[0.34em] text-zinc-500">Capture Runtime</p>
            <h2 class="mt-3 text-4xl font-semibold text-zinc-50">Traffic captures</h2>
            <p class="mt-4 max-w-4xl text-sm leading-7 text-zinc-400">
              Active runs and completed artifacts are shown here. Long captures are split into chunks so downloads stay manageable.
            </p>
            <div class="mt-4 grid gap-3 md:grid-cols-3">
              <div class="border border-zinc-800 bg-zinc-950/70 px-4 py-3">
                <p class="text-xs uppercase tracking-[0.28em] text-zinc-500">Storage Used</p>
                <p class="mt-2 text-xl font-semibold text-zinc-50" data-total-bytes><%= formatBytes(totalBytes) %></p>
              </div>
              <div class="border border-zinc-800 bg-zinc-950/70 px-4 py-3">
                <p class="text-xs uppercase tracking-[0.28em] text-zinc-500">Network Mode</p>
                <p class="mt-2 text-xl font-semibold text-zinc-50" data-network-mode><%= networkStatus.mode %></p>
              </div>
              <div class="border border-zinc-800 bg-zinc-950/70 px-4 py-3">
                <p class="text-xs uppercase tracking-[0.28em] text-zinc-500">Connection</p>
                <p class="mt-2 truncate text-xl font-semibold text-zinc-50" data-network-ssid><%= networkStatus.ssid || "none" %></p>
              </div>
            </div>
          </div>
          <div class="px-5 py-5" data-capture-list>
            <%- include("partials/capture-list", { captures }) %>
          </div>
        </section>
      </section>
    </main>
  </body>
</html>
